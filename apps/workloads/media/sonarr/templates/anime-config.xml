<Config>
    <LogLevel>info</LogLevel>
    <InstanceName>Sonarr Anime</InstanceName>
    <Port>8989</Port>
    <UrlBase/>
    <BindAddress>*</BindAddress>
    <SslPort>9898</SslPort>
    <EnableSsl>False</EnableSsl>
    <LaunchBrowser>True</LaunchBrowser>
    <ApiKey>{{ .Env.SONARR_API_KEY }}</ApiKey>
    <AuthenticationMethod>External</AuthenticationMethod>
    <PostgresUser>{{ .Env.POSTGRES_USER }}</PostgresUser>
    <PostgresPassword>{{ .Env.POSTGRES_PASSWORD }}</PostgresPassword>
    <PostgresPort>{{ .Env.POSTGRES_PORT }}</PostgresPort>
    <PostgresHost>{{ .Env.POSTGRES_HOST }}</PostgresHost>
    <PostgresMainDb>{{ .Env.POSTGRES_MAIN_DB }}</PostgresMainDb>
    <PostgresLogDb>{{ .Env.POSTGRES_LOG_DB }}</PostgresLogDb>
    <UpdateMechanism>Docker</UpdateMechanism>
    <AuthenticationRequired>Enabled</AuthenticationRequired>
    <SslCertPath/>
    <SslCertPassword/>
</Config>